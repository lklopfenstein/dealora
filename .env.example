# Optional automatic commerce monetization. Choose one provider after approval.
# Supported values: sovrn, skimlinks
NEXT_PUBLIC_COMMERCE_PROVIDER=

# Sovrn Commerce: campaign API key from the campaign Settings page.
NEXT_PUBLIC_SOVRN_COMMERCE_KEY=

# Skimlinks: exact HTTPS script URL from Publisher Hub > Install.
NEXT_PUBLIC_SKIMLINKS_SCRIPT_URL=
